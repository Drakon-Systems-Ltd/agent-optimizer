{
  "name": "@jarvis-drakon/agent-optimizer-openclaw-plugin",
  "version": "0.13.0",
  "description": "OpenClaw plugin exposing agent-optimizer's audit/plan/apply/rollback/scan verbs as agent tools. Mutating tools are approval-gated.",
  "author": "Drakon Systems Ltd <support@drakonsystems.com>",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://drakonsystems.com/products/agent-optimizer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drakon-Systems-Ltd/agent-optimizer.git",
    "directory": "openclaw-plugin"
  },
  "bugs": {
    "url": "https://github.com/Drakon-Systems-Ltd/agent-optimizer/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "agent-optimizer",
    "openclaw-audit",
    "openclaw-security",
    "openclaw-optimize",
    "token-optimization",
    "config-audit",
    "security-scanner",
    "clawhub",
    "drakon-systems"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:validate": "npm run build && openclaw plugins validate --entry ./dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.7",
    "typebox": "^1.3.3",
    "typescript": "^5.7.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.17"
    },
    "build": {
      "openclawVersion": "2026.7.1"
    }
  }
}
